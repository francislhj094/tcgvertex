# 🔐 Environment Variables Configuration
# Copy this file and fill in your actual values

# ============================================
# CRITICAL - STRIPE PAYMENT PROCESSING
# ============================================
# Get these from: https://dashboard.stripe.com/apikeys
# ⚠️ IMPORTANT: Use NEW keys only (revoke old exposed keys first)

STRIPE_SECRET_KEY=sk_live_YOUR_NEW_SECRET_KEY_HERE
STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_PUBLISHABLE_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# Note: Get webhook secret from Stripe Dashboard → Webhooks
# Create webhook endpoint: https://yourdomain.com/api/webhook
# Events to listen: checkout.session.completed


# ============================================
# EMAIL SERVICE - RESEND
# ============================================
# Get API key from: https://resend.com/api-keys
# ⚠️ Must verify your domain first in Resend dashboard

RESEND_API_KEY=re_YOUR_RESEND_API_KEY_HERE
SUPPORT_EMAIL=support@yourdomain.com

# Note: Change "support@yourdomain.com" to your actual support email


# ============================================
# FIREBASE ADMIN SDK
# ============================================
# Get from: Firebase Console → Project Settings → Service Accounts
# Click "Generate new private key" and copy the JSON

FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}

# Note: Must be valid JSON on one line (no line breaks in the value)


# ============================================
# TCGPLAYER AFFILIATE PROGRAM
# ============================================
# Sign up at: https://partner.tcgplayer.com/
# Get your partner ID from the affiliate dashboard

VITE_TCGPLAYER_AFFILIATE_ID=your_affiliate_partner_id_here

# Note: VITE_ prefix means this is exposed to frontend
# It's safe to expose affiliate IDs (they're meant to be public)


# ============================================
# EMAIL ALERTS SYSTEM (Optional)
# ============================================
# Only needed if deploying the email alert monitoring system
# Generate secure random keys with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

INTERNAL_API_KEY=generate_64_char_random_hex_string_here
CRON_SECRET=generate_64_char_random_hex_string_here
VITE_APP_URL=https://yourdomain.com

# INTERNAL_API_KEY: Used for internal API authentication
# CRON_SECRET: Used to secure the cron job endpoint
# VITE_APP_URL: Your production domain (for email links)


# ============================================
# FIREBASE CLIENT CONFIG (Frontend)
# ============================================
# Get from: Firebase Console → Project Settings → General
# Scroll down to "Your apps" → Web app → Firebase SDK snippet

VITE_FIREBASE_API_KEY=AIzaSyYOUR_API_KEY_HERE
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef123456
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Note: These are safe to expose (client-side Firebase config)


# ============================================
# POKEMON TCG API (Optional)
# ============================================
# Get free API key from: https://dev.pokemontcg.io/
# Not required but increases rate limits

POKEMON_TCG_API_KEY=your_pokemon_tcg_api_key_here

# Note: App works without this, but you'll have lower rate limits


# ============================================
# VERCEL DEPLOYMENT NOTES
# ============================================
#
# How to add these to Vercel:
# 1. Go to: https://vercel.com/dashboard
# 2. Select your project
# 3. Go to: Settings → Environment Variables
# 4. Add each variable above
# 5. Select: Production, Preview, Development
# 6. Click "Save"
#
# ⚠️ Important:
# - VITE_ variables require redeploy to take effect
# - Never commit this file with real values to git
# - Use different keys for development vs production
# - Test in preview deployment before production
#
# ============================================


